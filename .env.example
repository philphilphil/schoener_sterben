# Root of an external notes tree (e.g. Obsidian vault). Walked recursively.
# Files are picked up as drafts if their frontmatter has `draft: true` AND
# tags include `oper`. When set, a "Drafts" menu item appears in dev mode.
# DRAFTS_PATH=/path/to/notes/root

# OpenAI API key for utils/generate-tts.py
# OPENAI_API_KEY=sk-...
