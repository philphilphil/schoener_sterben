---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = 'Oper für alle!', bodyClass = '' } = Astro.props;
const fullTitle = title ? `${title} | Schöner Sterben` : 'Schöner Sterben';
const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/';
const allBodyClasses = [bodyClass, isHomepage ? 'homepage' : ''].filter(Boolean).join(' ');
---
<!DOCTYPE html>
<html lang="de" dir="auto" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="robots" content="index, follow">
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Phil Baum">
  <link rel="canonical" href={Astro.url.href}>
  <meta name="theme-color" content="#0a0505">
  <noscript>
    <style is:inline>
      #theme-toggle,
      .top-link {
        display: none;
      }
    </style>
  </noscript>
  <script is:inline>
    if (localStorage.getItem("pref-theme") === "light") {
      document.querySelector("html").dataset.theme = 'light';
    }
  </script>
</head>
<body class={allBodyClasses} id="top">
  <Header currentPath={currentPath} />
  <main class="main">
    <slot />
  </main>
  <Footer />
</body>
</html>
