---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Oper für alle!' } = Astro.props;
const fullTitle = title ? `${title} | Schöner Sterben` : 'Schöner Sterben';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="robots" content="index, follow">
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Phil Baum">
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url.href}>
  <meta property="og:locale" content="de_DE">
  <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="canonical" href={Astro.url.href}>
  <meta name="theme-color" content="#fafafa">
  <link rel="preload" href="/fonts/Draculitos.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/iAWriterQuattroV.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body id="top">
  <Header currentPath={currentPath} />
  <slot />
  <Footer />
</body>
</html>
