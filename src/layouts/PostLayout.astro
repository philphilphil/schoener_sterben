---
import BaseLayout from './BaseLayout.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import { formatDate } from '../utils/formatDate';

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  tags?: string[];
  summary?: string;
  image?: string;
  imageCaption?: string;
  readingTime?: number;
  draft?: boolean;
  hideMeta?: boolean;
  audioSrc?: string;
  prevPost?: { title: string; href: string } | null;
  nextPost?: { title: string; href: string } | null;
}

const { title, subtitle, date, tags = [], summary, image, imageCaption, readingTime, draft = false, hideMeta = false, audioSrc, prevPost, nextPost } = Astro.props;

const formattedDate = formatDate(date);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://schoenersterben.de';
const fullTitle = subtitle ? `${title} ${subtitle}` : title;
const articleUrl = Astro.url.href;
const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": fullTitle,
  "description": summary || '',
  "author": { "@type": "Person", "name": "Phil Baum" },
  "datePublished": date.toISOString(),
  "image": image ? `${siteUrl}${image}` : `${siteUrl}/images/og-default.png`,
  "url": articleUrl,
  "publisher": {
    "@type": "Organization",
    "name": "Schöner Sterben",
    "url": siteUrl,
  },
});
---
<BaseLayout title={title} description={summary} image={image} publishedDate={date} tags={tags}>
  <script type="application/ld+json" set:html={articleJsonLd} />
  <main class="article-wrapper">
    {!hideMeta && (
      <div class="article-meta">
        {tags.map((tag) => (
          <a href={`/tags/${tag.toLowerCase()}/`} class="tag">{tag}</a>
        ))}
        <span class="meta-date">{formattedDate}</span>
        {readingTime !== undefined && (
          <span class="meta-reading-time">&middot; {readingTime} Min. Lesezeit</span>
        )}
      </div>
    )}

    <h1 class="article-title">
      {title}
      {subtitle && <><br /><span class="article-subtitle">{subtitle}</span></>}
    </h1>

    {image && (
      <figure class="article-figure">
        <img src={image} alt={imageCaption || title} class="article-image">
        {imageCaption && <figcaption class="article-image-caption">{imageCaption}</figcaption>}
      </figure>
    )}

    <div class="post-content" data-pagefind-body>
      {audioSrc && <AudioPlayer src={audioSrc} />}
      <slot />
    </div>

    <footer class="post-footer">
      {(prevPost || nextPost) && (
        <nav class="paginav">
          {prevPost && (
            <a class="prev" href={prevPost.href}>
              <span class="title">&laquo; Vorheriger Beitrag</span>
              <br />
              <span>{prevPost.title}</span>
            </a>
          )}
          {nextPost && (
            <a class="next" href={nextPost.href}>
              <span class="title">Nächster Beitrag &raquo;</span>
              <br />
              <span>{nextPost.title}</span>
            </a>
          )}
        </nav>
      )}
    </footer>
  </main>
</BaseLayout>
