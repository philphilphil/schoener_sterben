---
/**
 * Backward-compatible wrapper around YouTubeConsentEmbed.
 * Maps the legacy `id` prop to `videoId`.
 */
import YouTubeConsentEmbed from './YouTubeConsentEmbed.astro';

interface Props {
  id: string;
  title?: string;
  start?: number;
  posterSrc?: string;
  description?: string;
}

const { id, title, start, posterSrc, description } = Astro.props;
---

<YouTubeConsentEmbed
  videoId={id}
  title={title}
  start={start}
  posterSrc={posterSrc}
  description={description}
/>
