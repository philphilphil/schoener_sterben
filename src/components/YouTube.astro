---
interface Props {
  id: string;
  title?: string;
  start?: number;
}
const { id, title = 'YouTube Video', start } = Astro.props;
const src = `https://www.youtube-nocookie.com/embed/${id}${start ? `?start=${start}` : ''}`;
---
<figure class="youtube-embed">
  <iframe
    src={src}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</figure>
