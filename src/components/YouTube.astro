---
interface Props {
  id: string;
  title?: string;
  start?: number;
}
const { id, title = 'YouTube Video', start } = Astro.props;
const src = `https://www.youtube-nocookie.com/embed/${id}${start ? `?start=${start}` : ''}`;
---
<figure class="youtube-embed">
  <iframe
    src={src}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</figure>

<style>
  .youtube-embed {
    margin: 1.5rem 0;
    padding: 0;
  }

  .youtube-embed iframe {
    aspect-ratio: 16 / 9;
    width: 100%;
    height: auto;
    border: none;
    border-radius: 4px;
  }
</style>
