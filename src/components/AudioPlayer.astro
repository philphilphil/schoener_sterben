---
interface Props {
  src: string;
}

const { src } = Astro.props;
---
<div class="audio-player" data-audio-player>
  <button class="audio-play-btn" data-play-btn aria-label="Abspielen">
    <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
      <polygon points="6,3 20,12 6,21" />
    </svg>
    <svg class="icon-pause" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" style="display:none">
      <rect x="5" y="3" width="4" height="18" />
      <rect x="15" y="3" width="4" height="18" />
    </svg>
  </button>

  <div class="audio-info">
    <span class="audio-label">Artikel anhören</span>
    <div class="audio-progress-wrap" data-progress-wrap>
      <div class="audio-progress-bar" data-progress-bar></div>
    </div>
    <span class="audio-time" data-time>0:00</span>
  </div>

  <button class="audio-speed-btn" data-speed-btn title="Wiedergabegeschwindigkeit">1x</button>

  <audio preload="metadata" data-audio>
    <source src={src} type="audio/mpeg" />
  </audio>
</div>

<script>
  document.querySelectorAll('[data-audio-player]').forEach((player) => {
    const audio = player.querySelector('[data-audio]') as HTMLAudioElement;
    const playBtn = player.querySelector('[data-play-btn]') as HTMLButtonElement;
    const iconPlay = player.querySelector('.icon-play') as SVGElement;
    const iconPause = player.querySelector('.icon-pause') as SVGElement;
    const progressWrap = player.querySelector('[data-progress-wrap]') as HTMLElement;
    const progressBar = player.querySelector('[data-progress-bar]') as HTMLElement;
    const timeDisplay = player.querySelector('[data-time]') as HTMLElement;
    const speedBtn = player.querySelector('[data-speed-btn]') as HTMLButtonElement;
    const speeds = [1, 1.25, 1.5, 1.75, 2];
    let speedIndex = 0;

    speedBtn.addEventListener('click', () => {
      speedIndex = (speedIndex + 1) % speeds.length;
      audio.playbackRate = speeds[speedIndex];
      speedBtn.textContent = `${speeds[speedIndex]}x`;
    });

    function formatTime(s: number): string {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    playBtn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play();
      } else {
        audio.pause();
      }
    });

    audio.addEventListener('play', () => {
      iconPlay.style.display = 'none';
      iconPause.style.display = '';
      playBtn.setAttribute('aria-label', 'Pause');
    });

    audio.addEventListener('pause', () => {
      iconPlay.style.display = '';
      iconPause.style.display = 'none';
      playBtn.setAttribute('aria-label', 'Abspielen');
    });

    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      const pct = (audio.currentTime / audio.duration) * 100;
      progressBar.style.width = `${pct}%`;
      timeDisplay.textContent = `${formatTime(audio.currentTime)} / ${formatTime(audio.duration)}`;
    });

    audio.addEventListener('loadedmetadata', () => {
      timeDisplay.textContent = `0:00 / ${formatTime(audio.duration)}`;
    });

    progressWrap.addEventListener('click', (e: MouseEvent) => {
      const rect = progressWrap.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      audio.currentTime = pct * audio.duration;
    });
  });
</script>

<style>
  .audio-player {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border: 1px solid var(--divider);
    border-radius: var(--radius);
    background: var(--code-bg);
    margin-bottom: 1.25rem;
  }

  .audio-play-btn {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: var(--accent);
    color: var(--btn-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s;
  }

  .audio-play-btn:hover {
    opacity: 0.85;
  }

  .audio-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .audio-label {
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .audio-progress-wrap {
    width: 100%;
    height: 6px;
    background: var(--divider);
    border-radius: 3px;
    cursor: pointer;
    overflow: hidden;
  }

  .audio-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.1s linear;
  }

  .audio-time {
    font-size: 0.75rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .audio-speed-btn {
    flex-shrink: 0;
    padding: 4px 8px;
    border: 1px solid var(--divider);
    border-radius: var(--radius);
    background: transparent;
    color: var(--muted);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .audio-speed-btn:hover {
    color: var(--text);
    border-color: var(--text);
  }
</style>
