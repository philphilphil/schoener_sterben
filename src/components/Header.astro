---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const menuItems = [
  { name: 'Blog', url: '/' },
  { name: 'Archiv', url: '/browse/' },
  { name: 'Opern-FAQ', url: '/faq/' },
  { name: 'Über', url: '/about/' },
];

if (import.meta.env.DEV && import.meta.env.DRAFTS_PATH) {
  menuItems.push({ name: 'Drafts', url: '/drafts/' });
}
---
<header class="site-header">
  <div class="container">
    <a href="/" class="masthead"><img src="/images/opera-stuttgart.svg" class="masthead-building" alt="Schöner Sterben" /><span>Schöner Sterben</span></a>
    <div class="subtitle">Kurze Texte über Oper</div>
  </div>
  <nav class="site-nav">
    <div class="container">
      <ul>
        {menuItems.map((item) => (
          <li>
            <a
              href={item.url}
              class={currentPath === item.url || (item.url !== '/' && currentPath.startsWith(item.url)) ? 'active' : ''}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>
