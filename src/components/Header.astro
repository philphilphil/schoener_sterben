---
interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const menuItems = [
  { name: 'Blog', url: '/' },
  { name: 'Archiv', url: '/browse/' },
  { name: 'Opern-FAQ', url: '/faq/' },
  { name: 'Über', url: '/about/' },
];
---
<header class="site-header">
  <div class="container">
    <a href="/" class="masthead">Schöner Sterben</a>
    <div class="subtitle">Oper für alle!</div>
  </div>
  <nav class="site-nav">
    <div class="container">
      <ul>
        {menuItems.map((item) => (
          <li>
            <a
              href={item.url}
              class={currentPath === item.url || (item.url !== '/' && currentPath.startsWith(item.url)) ? 'active' : ''}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>
