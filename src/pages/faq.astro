---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "faq");
const faqData = (entry!.data as any).categories;

// Build JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqData.flatMap((cat: any) =>
    cat.questions.map((q: any) => ({
      "@type": "Question",
      name: q.q,
      acceptedAnswer: { "@type": "Answer", text: q.a.replace(/<[^>]*>/g, "") },
    })),
  ),
};
---

<BaseLayout title="Opern-FAQ" description="Häufige Fragen rund um die Oper — von Dresscode bis Libretto.">
  <div class="faq-page">
    <div class="faq-body">
      {
        faqData.map((category: any) => (
          <section class="faq-category">
            <h2 class="faq-category-title">{category.category}</h2>
            {category.questions.map((item: any) => (
              <details class="faq-item">
                <summary>{item.q}</summary>
                <div class="faq-answer" set:html={item.a} />
              </details>
            ))}
          </section>
        ))
      }
    </div>
  </div>

  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd).replace(/</g, "\\u003c")}
  />
</BaseLayout>
