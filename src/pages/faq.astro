---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqData = [
  {
    category: 'Besuch',
    questions: [
      { q: 'Muss ich mich für die Oper schick machen?', a: 'Nein, zieh an was du willst. Je tradiotioneller die aufhührung desto mehr leute werden schick angezogen sein aber es wird sich niemand daran stören wenn du im Hoodie kommst.' },
      { q: 'Darf ich essen/trinken mitnehmen?', a: 'Ja. Offiziell darf man es nicht mit in den Saal nehmen aber wenn du es in der Tasche lässt wird keiner nachfragen. Dann eben in der Pause im Foyer essen und trinken.' },
      { q: 'Ist Oper nicht viel zu teuer?', a: 'Nein. Es gibt in den meisten Opern Tickets ab 20 Euro. Die Sicht und Akkustik wird nicht optimal sein, trotzdem wird man die auffühgun gut erleben können.' },
      { q: 'Muss man während der Aufführung still sein?', a: 'Ja. Opern werden (mit modernen Ausnahmen) ohne elektronische Verstärkung gespielt. Im Saal ist es daher manchmal sehr Leise (manchmal aber auch sehr Laut). Kurz dem Nachbarn etwas ins Ohr flüstern ist in Ordnung, ansonsten die gespräche für die Pause aufheben. Auch auf Kaugumi kauen sollte eher verzichtet werden, da das die MithörerInnen sehr stören kann.' },
      { q: 'Was macht der Regisseur?', a: 'Der Regisseur oder die Regisseurin interpretiert oder Ignoriert die scenischen anweisungen des Interpreten der Oper und inzeniert die gesamte bühne. Bühnenbild, verhalten der SängerInnen und zum teil auch Besetzung sind ihre Aufgabe.' },
      { q: 'Darf man in der Oper Buhen?', a: 'Ja. Bei Kontroversen interpretationen ist Buhen nicht ungewöhnlich. Wird direkt nach dem Schlussvorhang (ende) Gebuht, gilt das Buhen der Regie, nicht den Sängern. Sänger werden (in der Regel) nicht ausgebuht. Wenn (bei Premieren) das Regieteam auf die Bühne kommt darf man seiner Meinung freien lauf lassen.' },
    ],
  },
  {
    category: 'Begriffe',
    questions: [
      { q: 'Sopran, Bariton, Bass,..', a: 'Bezeichnungen für den Stimmunfang der SängerInnen. Das bedeutet, wie tief bis hoch sie singen können. Illustration von <a href="https://de.wikipedia.org/wiki/Stimmlage">Wikipedia</a>: <img src="https://upload.wikimedia.org/wikipedia/commons/7/7a/Tonh%C3%B6hen_der_stimmlagen.png" alt="Stimmlagen">' },
      { q: 'Akt', a: 'Eine Oper besteht aus mehren Teilen, genannt "Akt". Es gibt auch Opern die nur aus einem Akt bestehen. Oft wird zwischen Akten die Bühne umgebaut.' },
    ],
  },
  {
    category: 'Sonstiges',
    questions: [
      { q: 'Ist Oper nicht nur Musical in alt?', a: 'Nein. Beides sind unterschiedliche formen des Musiktheaters.' },
      { q: 'Ist dieser Blog KI generierter müll?', a: 'Nein. Alles vom Mensch geschrieben :). KI wurde zu Faktenchecks und dem anpassen des Themes verwendet.' },
    ],
  },
];

// Build JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqData.flatMap((cat) =>
    cat.questions.map((q) => ({
      "@type": "Question",
      name: q.q,
      acceptedAnswer: { "@type": "Answer", text: q.a.replace(/<[^>]*>/g, '') },
    }))
  ),
};
---
<BaseLayout title="Opern-FAQ" bodyClass="list">
  <article class="post-single">
    <header class="post-header">
      <h1 class="post-title entry-hint-parent">Opern-FAQ</h1>
    </header>

    <div class="faq-container">
      {faqData.map((category) => (
        <section class="faq-category">
          <h2 class="faq-category-title">{category.category}</h2>
          {category.questions.map((item) => (
            <details class="faq-item">
              <summary>{item.q}</summary>
              <div class="faq-answer" set:html={item.a} />
            </details>
          ))}
        </section>
      ))}
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
