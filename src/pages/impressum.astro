---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Impressum" description="Impressum und Angaben gemäß § 5 DDG.">
  <article class="impressum-page">
    <h1>Impressum</h1>
    <div class="impressum-content">

  <h2>Angaben gemäß § 5 DDG</h2>
  <p>
    Philipp Baum<br />
    c/o Webix Solutions GmbH<br />
    Zuckerfabrik 14<br />
    70376 Stuttgart
  </p>

  <p>
    E-Mail: phil@schoenersterben.de
  </p>

  <h2>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
  <p>
    Philipp Baum<br />
    c/o Webix Solutions GmbH<br />
    Zuckerfabrik 14<br />
    70376 Stuttgart
  </p>


    </div>
  </article>
</BaseLayout>

<style>
  .impressum-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .impressum-page h1 {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .impressum-content h2 {
    font-family: var(--font-headline);
    font-size: 1.1rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .impressum-content h3 {
    font-family: var(--font-headline);
    font-size: 1rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .impressum-content p {
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }
</style>
