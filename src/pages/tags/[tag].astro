---
import ListLayout from '../../layouts/ListLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts } from '../../utils/posts';
import { estimateReadingTime } from '../../utils/readingTime';
import { getPostSlug } from '../../utils/getPostSlug';

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  const tagMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const key = tag.toLowerCase();
      if (!tagMap.has(key)) tagMap.set(key, []);
      tagMap.get(key)!.push(post);
    }
  }
  return [...tagMap.entries()].map(([tag, posts]) => ({
    params: { tag },
    props: { posts: posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()) },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const displayTag = posts.length > 0
  ? posts[0].data.tags.find((t: string) => t.toLowerCase() === tag) || tag
  : tag;
---
<ListLayout title={displayTag}>
  <header class="browse-hero">
    <h1 class="browse-title">{displayTag}</h1>
    <p class="browse-subtitle">{posts.length} {posts.length === 1 ? 'Beitrag' : 'Beiträge'}</p>
  </header>

  {posts.map((post) => {
    const slug = getPostSlug(post);
    return (
      <PostCard
        title={post.data.title}
        href={`/posts/${slug}/`}
        summary={post.data.summary}
        date={post.data.date}
        readingTime={post.body ? estimateReadingTime(post.body) : undefined}
        class="post-entry tag-entry"
      />
    );
  })}
</ListLayout>
