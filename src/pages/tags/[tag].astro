---
import ListLayout from '../../layouts/ListLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', (p) => p.id.startsWith('posts/') && !p.data.draft);
  const tags = new Set<string>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      tags.add(tag.toLowerCase());
    }
  }
  return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = await getCollection('posts', (entry) => {
  return entry.id.startsWith('posts/') && !entry.data.draft;
});
const posts = allPosts
  .filter((p) => p.data.tags.some((t: string) => t.toLowerCase() === tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const displayTag = posts.length > 0
  ? posts[0].data.tags.find((t: string) => t.toLowerCase() === tag) || tag
  : tag;

function estimateReadingTime(body: string): number {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---
<ListLayout title={displayTag}>
  <header class="page-header">
    <Breadcrumbs items={[{ label: 'Tags', href: '/tags/' }]} />
    <h1>{displayTag}</h1>
  </header>

  {posts.map((post) => {
    const slug = post.data.slug || post.id.split('/').pop()?.replace(/\.mdx?$/, '');
    return (
      <PostCard
        title={post.data.title}
        href={`/posts/${slug}/`}
        summary={post.data.summary}
        date={post.data.date}
        readingTime={post.body ? estimateReadingTime(post.body) : undefined}
        class="post-entry tag-entry"
      />
    );
  })}
</ListLayout>
