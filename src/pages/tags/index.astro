---
import ListLayout from '../../layouts/ListLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', (entry) => {
  return entry.id.startsWith('posts/') && !entry.data.draft;
});

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---
<ListLayout title="Alle Tags">
  <header class="page-header">
    <h1>Alle Tags</h1>
  </header>
  <ul class="terms-tags">
    {sortedTags.map(([tag, count]) => (
      <li>
        <a href={`/tags/${tag.toLowerCase()}/`}>
          {tag} <sup><strong><sup>{count}</sup></strong></sup>
        </a>
      </li>
    ))}
  </ul>
</ListLayout>
