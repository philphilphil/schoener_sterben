---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../utils/posts';
import { estimateReadingTime } from '../utils/readingTime';
import { getPostSlug } from '../utils/getPostSlug';
import { formatDate } from '../utils/formatDate';

const posts = await getPublishedPosts();
const featuredPost = posts[0];
const teaserPosts = posts.slice(1, 4);
const remainingPosts = posts.slice(4);
---
<BaseLayout title="" description="Oper für alle!">
  <main>
    <div class="container">

      <section class="featured-hero">
        <article class="featured-main">
          {featuredPost.data.image ? (
            <a href={`/posts/${getPostSlug(featuredPost)}/`}>
              <img src={featuredPost.data.image} alt="" class="featured-image">
            </a>
          ) : (
            <div class="image-placeholder">Bild</div>
          )}
          {featuredPost.data.tags?.[0] && (
            <a href={`/tags/${featuredPost.data.tags[0]}/`} class="tag">{featuredPost.data.tags[0]}</a>
          )}
          <h2>
            <a href={`/posts/${getPostSlug(featuredPost)}/`}>
              {featuredPost.data.title}
              {featuredPost.data.subtitle && <span class="featured-subtitle"> {featuredPost.data.subtitle}</span>}
            </a>
          </h2>
          {featuredPost.data.summary && (
            <p class="excerpt">{featuredPost.data.summary}</p>
          )}
          <span class="date">{formatDate(featuredPost.data.date)}</span>
        </article>
      </section>

      {teaserPosts.length > 0 && (
        <section class="teaser-grid">
          {teaserPosts.map((post) => (
            <article class="teaser-post">
              {post.data.image ? (
                <a href={`/posts/${getPostSlug(post)}/`}>
                  <img src={post.data.image} alt="" class="teaser-image">
                </a>
              ) : (
                <div class="image-placeholder">Bild</div>
              )}
              {post.data.tags?.[0] && (
                <a href={`/tags/${post.data.tags[0]}/`} class="tag">{post.data.tags[0]}</a>
              )}
              <h3>
                <a href={`/posts/${getPostSlug(post)}/`}>
                  {post.data.title}
                  {post.data.subtitle && <span class="teaser-subtitle"> {post.data.subtitle}</span>}
                </a>
              </h3>
              {post.data.summary && (
                <p class="excerpt">{post.data.summary}</p>
              )}
              <span class="date">{formatDate(post.data.date)}</span>
            </article>
          ))}
        </section>
      )}

      {remainingPosts.length > 0 && (
        <section class="more-posts">
          <hr class="section-divider">
          <h3 class="section-title">Weitere Beiträge</h3>
          <div class="more-posts-list">
            {remainingPosts.map((post) => {
              const readingTime = post.body ? estimateReadingTime(post.body) : undefined;
              return (
                <a href={`/posts/${getPostSlug(post)}/`} class="more-post-item">
                  <span class="more-post-title">{post.data.title}{post.data.subtitle && ` ${post.data.subtitle}`}</span>
                  <span class="more-post-meta">
                    {formatDate(post.data.date)}
                    {readingTime && ` · ${readingTime} Min.`}
                  </span>
                </a>
              );
            })}
          </div>
        </section>
      )}

    </div>
  </main>
</BaseLayout>
