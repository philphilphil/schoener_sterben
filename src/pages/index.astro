---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', (entry) => {
  return entry.id.startsWith('posts/') && !entry.data.draft;
});
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function estimateReadingTime(body: string): number {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const [featured, ...rest] = posts;
const featuredSlug = featured?.data.slug || featured?.id.split('/').pop()?.replace(/\.mdx?$/, '');

const editionDate = new Date().toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
});
---
<BaseLayout title="" description="Oper für alle!">
  <div class="editorial-home">
    <div class="edition-line">
      <span>{editionDate}</span>
      <span>{posts.length} Beiträge</span>
    </div>

    {featured && (
      <section class="lead-article">
        <div class="lead-label">Neuester Beitrag</div>
        <a href={`/posts/${featuredSlug}/`} class="lead-link">
          <h2 class="lead-title">{featured.data.title}</h2>
          {featured.data.summary && (
            <p class="lead-summary">{featured.data.summary}</p>
          )}
          <div class="lead-meta">
            <PostMeta date={featured.data.date} readingTime={featured.body ? estimateReadingTime(featured.body) : undefined} />
          </div>
        </a>
      </section>
    )}

    {rest.length > 0 && (
      <section class="post-index">
        <div class="post-index-label">Weitere Beiträge</div>
        {rest.map((post, i) => {
          const slug = post.data.slug || post.id.split('/').pop()?.replace(/\.mdx?$/, '');
          return (
            <a href={`/posts/${slug}/`} class="post-index-item">
              <span class="post-index-number">{String(i + 2).padStart(2, '0')}</span>
              <div class="post-index-body">
                <h3 class="post-index-title">{post.data.title}</h3>
                <div class="post-index-meta">
                  <PostMeta date={post.data.date} />
                </div>
              </div>
            </a>
          );
        })}
      </section>
    )}
  </div>
</BaseLayout>
